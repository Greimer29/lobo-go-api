NODE_ENV=production
HOST=0.0.0.0
PORT=3333
LOG_LEVEL=info
TZ=UTC

APP_KEY=change_me
APP_URL=https://your-public-api.up.railway.app
JWT_SECRET=change_me

SESSION_DRIVER=cookie
CORS_ALLOW_LAN=false
# CORS_ORIGIN=https://your-web-domain.com,capacitor://localhost,http://localhost

RUN_MIGRATIONS_ON_BOOT=true
RUN_DEMO_SEED_ON_BOOT=false

# MySQL destino público (Railway MySQL o externo)
MYSQL_TRACKING_HOST=change_me
MYSQL_TRACKING_PORT=3306
MYSQL_TRACKING_DATABASE=tracking_db
MYSQL_TRACKING_USER=tracking_user
MYSQL_TRACKING_PASSWORD=change_me
MYSQL_TRACKING_SSL=false

# Endpoint público para mapas/live tracking
PUBLIC_TRACKING_WS_PORT=3334
# En API pública (Railway), normalmente desactivado para evitar loops local<->public.
PUBLIC_SYNC_OUTBOUND_ENABLED=false
PUBLIC_SYNC_RECONCILE_ENABLED=false

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
