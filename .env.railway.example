NODE_ENV=production
PORT=3333
HOST=0.0.0.0
APP_KEY=
APP_URL=https://your-railway-api.up.railway.app
LOG_LEVEL=info
SESSION_DRIVER=cookie
CORS_ALLOW_LAN=false
CORS_ORIGIN=https://your-frontend.com
# Conexión MySQL Railway (nombres heredados, host es mysql.railway.internal)
MYSQL_TRACKING_HOST=mysql.railway.internal
MYSQL_TRACKING_PORT=3306
MYSQL_TRACKING_DATABASE=railway
MYSQL_TRACKING_USER=root
MYSQL_TRACKING_PASSWORD=
MYSQL_TRACKING_SSL=false
# Validación del bridge entrante
CORP_BRIDGE_API_KEY=
# Operación
RUN_MIGRATIONS_ON_BOOT=true
RUN_DEMO_SEED_ON_BOOT=false
# Kill-switch
EMERGENCY_DISABLE=false
