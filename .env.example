# Node
TZ=UTC
PORT=3333
# Escuchar en todas las interfaces (acceso desde otros equipos en la LAN)
HOST=0.0.0.0
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
# URL publica del API (para enlaces/redirects). En LAN usa la IP de este equipo, ej. http://192.168.1.10:3333
APP_URL=http://localhost:3333

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS
#--------------------------------------------------------------------
# Lista explícita (recomendado en producción), separada por comas:
# CORS_ORIGIN=http://localhost:5173,http://192.168.1.10:8080
# Sin lista: permitir orígenes en redes privadas (LAN), p. ej. 192.168.x.x, 10.x, 172.16-31.x
CORS_ALLOW_LAN=true

# Auth
JWT_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# Usuario demo (tras migraciones): node ace db:seed --files database/seeders/demo_user_seeder
# Email demo@local.test / contraseña demo1234

# SQL Server corporativo (lectura; UPDATE en SADEV si activas push de sync/entrega). Ej.: host BASS o IP; instancia: HOST\\INSTANCIA
SQLSERVER_HOST=127.0.0.1
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=LOBOGOLDGREI
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=
SQLSERVER_ENCRYPT=false
# Tablas corporativas (por defecto en código: SADEV, SAFACT, SAITEMFAC en esquema dbo).
# Solo define estas variables si en tu base los nombres o el esquema son distintos.
# SQLSERVER_SCHEMA=dbo
# SQLSERVER_TABLE_SADEV=SADEV
# SQLSERVER_TABLE_SAFACT=SAFACT
# SQLSERVER_TABLE_SAITEMFACT=SAITEMFAC
# SQLSERVER_TABLE_SADEPO=SADEPO
# Nombres de columnas de coordenadas en la tabla de depósitos (SADEPO) si no son Latitud / Longitud (p. ej. Lng, Long en tu ERP):
# SQLSERVER_SADEPO_COL_LATITUD=Latitud
# SQLSERVER_SADEPO_COL_LONGITUD=Longitud
# Si falta longitud o da "Invalid column name 'Longitud'": SQLSERVER_SADEPO_OMIT_LONGITUD=true
# o define SQLSERVER_SADEPO_COL_LONGITUD=ElNombreReal
# Sin columnas de coordenadas: SQLSERVER_SADEPO_OMIT_COORDS=true
# Si "Invalid column name 'Direccion'" o no existe: SQLSERVER_SADEPO_OMIT_DIRECCION=true
# o indica el nombre real: SQLSERVER_SADEPO_COL_DIRECCION=...
# Lo mismo para descripción: SQLSERVER_SADEPO_OMIT_DESCRIP o SQLSERVER_SADEPO_COL_DESCRIP=...
# Código de depósito con otro nombre: SQLSERVER_SADEPO_COL_CODUBIC=CodUbic
# Join opcional con SAPROD (Precio1 respaldo si Precio de línea nulo; Unidad = unidad de venta). Si no existe: SQLSERVER_SKIP_SAPROD_JOIN=true
# SQLSERVER_TABLE_SAPROD=SAPROD
# SQLSERVER_SKIP_SAPROD_JOIN=false
# Sin tabla de líneas: SQLSERVER_SKIP_ITEM_LINES=true
#
# Cierre de entrega: escribir SADEV.Status en SQL Server al completar en tracking (requiere permiso UPDATE).
# SQLSERVER_SADEV_PUSH_COMPLETION_ENABLED=true
# Valor ERP para "entregado" en SADEV.Status (por defecto en código: 2).
# SQLSERVER_SADEV_DELIVERED_STATUS=2
# En sync SQL→MySQL, no traer filas ya entregadas en corporativo (por defecto true en código).
# SQLSERVER_SADEV_SYNC_SKIP_DELIVERED=true
#
# Tras importar a MySQL, marcar SADEV.Status como “ya en tracking” (por defecto 1 en LOBO; requiere UPDATE).
# SQLSERVER_SADEV_PUSH_SYNCED_STATUS_ENABLED=true
# SQLSERVER_SADEV_SYNCED_STATUS=1
# No traer en sync filas con ese Status (por defecto true).
# SQLSERVER_SADEV_SYNC_SKIP_HANDOFF=true
#
# Sync automático SADEV→MySQL: `npm run dev` incluye el worker (sched). En Docker: servicio `scheduler` en compose.
# Omitir la variable = sync activo. Para desactivar (p. ej. sin SQL Server local): SADEV_AUTO_SYNC_ENABLED=false
# Opcional: expresión cron node-cron (5 o 6 campos). Si no se define, cada 15 segundos.
# SADEV_AUTO_SYNC_CRON=* * * * *
# SADEV_AUTO_SYNC_LIMIT=100
# Status SADEV a traer en el job (CSV; en LOBO 0 = pendiente). Por defecto en comando: 0.
# SADEV_AUTO_SYNC_PENDING_STATUSES=0
# Candado en MySQL para varias réplicas del scheduler (tabla sync_job_leases tras migración).
# SADEV_AUTO_SYNC_DISTRIBUTED_LOCK=true
# SADEV_AUTO_SYNC_LEASE_TTL_SECONDS=120
#
# POST /tracking/pedidos/sync: sin corporateStatuses solo trae Status 0 (LOBO pendiente). Opcional: corporateStatuses=0 o CSV explícito.
#
# Rendimiento (DBA, SQL Server): índice recomendado en SADEV si hay mucho volumen, p. ej.
#   NONCLUSTERED INDEX IX_SADEV_Status_NumeroD ON dbo.SADEV (Status ASC, NumeroD DESC)
# Ajustar esquema/nombre de tabla según SQLSERVER_SCHEMA / SQLSERVER_TABLE_SADEV.

# MySQL tracking (read/write)
MYSQL_TRACKING_HOST=127.0.0.1
MYSQL_TRACKING_PORT=3306
MYSQL_TRACKING_DATABASE=tracking_db
MYSQL_TRACKING_USER=tracking_user
MYSQL_TRACKING_PASSWORD=
MYSQL_TRACKING_SSL=false

# Tracking público (Railway / gateway internet)
# URL base destino para outbox interno -> público.
# Si el tracking público es esta misma API expuesta, usa APP_URL.
# PUBLIC_TRACKING_BASE_URL=http://127.0.0.1:3333
PUBLIC_TRACKING_BASE_URL=
PUBLIC_TRACKING_API_KEY=
PUBLIC_TRACKING_SIGNING_SECRET=
# En desarrollo: permite eventos sin firma.
PUBLIC_TRACKING_ACCEPT_UNSIGNED=true
# WS público para mapa en vivo.
PUBLIC_TRACKING_WS_PORT=3334
# Scheduler de sync local -> público (outbox): por defecto cada 20s, con dedupe por eventId.
# PUBLIC_SYNC_OUTBOUND_ENABLED=true
# Tras cada evento encolado, intento de envío en segundo plano (no hace falta correr solo el scheduler).
# PUBLIC_SYNC_IMMEDIATE_FLUSH=false
# PUBLIC_SYNC_IMMEDIATE_FLUSH_LIMIT=100
# PUBLIC_SYNC_OUTBOUND_CRON=*/20 * * * * *
# PUBLIC_SYNC_OUTBOUND_LIMIT=200
# Reconciliación público -> local (eventos): por defecto cada 45s, usa cursor en memoria + lookback inicial.
# PUBLIC_SYNC_RECONCILE_ENABLED=true
# PUBLIC_SYNC_RECONCILE_CRON=*/45 * * * * *
# PUBLIC_SYNC_RECONCILE_LOOKBACK_SECONDS=120
# PUBLIC_SYNC_RECONCILE_LIMIT=500

# Geocoding opcional (si admin ingresa solo dirección para destino)
# GOOGLE_MAPS_GEOCODING_API_KEY=

# Security and operation
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120